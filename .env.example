# Telegram
TELEGRAM_BOT_TOKEN=xxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: a random string to validate webhooks are from Telegram (set same value when registering webhook)
TELEGRAM_WEBHOOK_SECRET=

# Google Gemini (free at aistudio.google.com — no credit card)
GEMINI_API_KEY=AIzaxxxxxxxx

# OpenAI (optional — only needed for GPT models)
OPENAI_API_KEY=sk-proj-xxxxxxxx

# Active AI model (default: gemini-2.5-flash)
# Options: gemini-2.5-flash, gemini-2.0-flash, gpt-4o-mini, gpt-4o
ACTIVE_MODEL=gemini-2.5-flash

# Admin panel password (set a strong password in production)
ADMIN_PASSWORD=changeme

# Google Calendar
# Local dev: path to your downloaded service account JSON
# Render: leave this blank — file is read from /etc/secrets/service_account.json automatically
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# App settings
BUSINESS_NAME="Your Business Name"
BUSINESS_HOURS="Monday-Friday, 9am-5pm"
APPOINTMENT_DURATION_MINUTES=30
# Max allowed is 30 minutes per person (enforced in config.py regardless of what you set here)
